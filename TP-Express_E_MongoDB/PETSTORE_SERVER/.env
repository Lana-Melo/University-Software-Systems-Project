# -----
# .env
# -----

# Porto de escuta de pedidos à API.
PORT=3001

# Configuração de acesso à base de dados MongoDB.
DB_URI='mongodb://localhost:27017/petstorebd'

# Valor de salt rounds para uso no bcrypt.
SALT_ROUNDS=10

# Chave usada na geração de JSON Web Tokens.
JWT_SECRET='chave_bem_segura'

# Validade de um JSON Web Token.
TOKEN_EXPIRATION='1h'

# -----